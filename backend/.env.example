PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/tradeflow

# Optional: enable SSL for managed Postgres providers (Railway/Supabase/etc)
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# REQUIRED: Must be at least 32 random characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_minimum_32_char_random_secret_here_abc123

# REQUIRED in production: comma-separated list of allowed frontend origins
# Example: FRONTEND_URL=https://app.yourdomain.com
# In development with npm start proxy this can be: FRONTEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

NODE_ENV=development

# Optional: initialize DB schema.sql on startup if DB is empty
AUTO_DB_INIT=false

# Optional: seed demo tenant/users/data on startup (idempotent)
DEMO_SEED=false
DEMO_PASSWORD=Tradeflow@12345

# Optional: one-time seeding via API endpoint (must be enabled and protected)
DEMO_SEED_ENDPOINT=false
# Set a strong random token and call POST /api/admin/demo-seed with header x-seed-token
SEED_TOKEN=replace_with_random_token
