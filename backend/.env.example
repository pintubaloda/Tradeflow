PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/tradeflow

# REQUIRED: Must be at least 32 random characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_minimum_32_char_random_secret_here_abc123

# REQUIRED in production: comma-separated list of allowed frontend origins
# Example: FRONTEND_URL=https://app.yourdomain.com
# In development with npm start proxy this can be: FRONTEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

NODE_ENV=development
